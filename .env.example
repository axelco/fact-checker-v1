# Copier ce fichier en .env et remplir les valeurs
ANTHROPIC_API_KEY=sk-ant-...
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/fact-checker-v1"

# Betterstack — token différent par environnement (UAT / prod)
# Laisser vide en dev local : les logs vont uniquement dans la console
BETTERSTACK_SOURCE_TOKEN=

# Basic Auth — protection d'accès sur staging / production
# Mettre à 'true' pour activer (jamais en local)
BASIC_AUTH_ENABLED=false
BASIC_AUTH_USER=admin
BASIC_AUTH_PASS=
