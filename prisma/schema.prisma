generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Analysis {
  id             String   @id @default(cuid())
  canonicalTopic String   @unique
  originalQuery  String
  verdict        String
  score          Int
  result         Json
  hitCount       Int      @default(1)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@map("analyses")
}
