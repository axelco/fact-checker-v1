generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// --- Modèles à venir ---

model Analysis {
  id          String   @id @default(cuid())
  query       String
  verdict     String
  score       Int
  result      Json
  createdAt   DateTime @default(now())

  @@map("analyses")
}
